<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE jasperReport PUBLIC
        "-//JasperReports//DTD Report Design//EN"
        "http://jasperreports.sourceforge.net/dtds/jasperreport.dtd">

<jasperReport name="EmployeeReport"
              pageWidth="595"
              pageHeight="842"
              columnWidth="555"
              leftMargin="20"
              rightMargin="20"
              topMargin="20"
              bottomMargin="20">

    <!-- Fields (must match EmployeeDTO getters) -->
    <field name="employeeId" class="java.lang.String"/>
    <field name="employeeName" class="java.lang.String"/>
    <field name="employeeRole" class="java.lang.String"/>
    <field name="employeeSalary" class="java.lang.Double"/>
    <field name="employeeContact" class="java.lang.String"/>
    <field name="employeeHireDate" class="java.time.LocalDate"/>

    <!-- Title -->
    <title>
        <band height="40">
            <textField>
                <reportElement x="0" y="10" width="555" height="30"/>
                <textElement textAlignment="Center">
                    <font size="18" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Employee Report"]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- Column Header -->
    <columnHeader>
        <band height="25">
            <staticText><reportElement x="0" y="0" width="60" height="25"/><text><![CDATA[ID]]></text></staticText>
            <staticText><reportElement x="60" y="0" width="120" height="25"/><text><![CDATA[Name]]></text></staticText>
            <staticText><reportElement x="180" y="0" width="100" height="25"/><text><![CDATA[Role]]></text></staticText>
            <staticText><reportElement x="280" y="0" width="80" height="25"/><text><![CDATA[Salary]]></text></staticText>
            <staticText><reportElement x="360" y="0" width="115" height="25"/><text><![CDATA[Contact]]></text></staticText>
            <staticText><reportElement x="475" y="0" width="80" height="25"/><text><![CDATA[Hire Date]]></text></staticText>
        </band>
    </columnHeader>

    <!-- Detail -->
    <detail>
        <band height="25">
            <textField><reportElement x="0" y="0" width="60" height="25"/><textFieldExpression><![CDATA[$F{employeeId}]]></textFieldExpression></textField>
            <textField><reportElement x="60" y="0" width="120" height="25"/><textFieldExpression><![CDATA[$F{employeeName}]]></textFieldExpression></textField>
            <textField><reportElement x="180" y="0" width="100" height="25"/><textFieldExpression><![CDATA[$F{employeeRole}]]></textFieldExpression></textField>
            <textField><reportElement x="280" y="0" width="80" height="25"/><textFieldExpression><![CDATA[$F{employeeSalary}]]></textFieldExpression></textField>
            <textField><reportElement x="360" y="0" width="115" height="25"/><textFieldExpression><![CDATA[$F{employeeContact}]]></textFieldExpression></textField>
            <textField><reportElement x="475" y="0" width="80" height="25"/><textFieldExpression><![CDATA[$F{employeeHireDate}]]></textFieldExpression></textField>
        </band>
    </detail>

</jasperReport>
